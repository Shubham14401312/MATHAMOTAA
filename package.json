{
  "name": "mathamota",
  "private": true,
  "version": "1.0.0",
  "engines": {
    "node": "22.x",
    "npm": "10.x"
  },
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "npm --workspace apps/api run dev",
    "dev:web": "npm --workspace apps/web run dev",
    "build": "npm --workspace apps/web run build",
    "build:all": "npm run build",
    "start": "node apps/api/src/server.js",
    "hash-admin": "node apps/api/src/security.js",
    "serve": "npm run start"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
